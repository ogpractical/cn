Q2) B) Write a C program to implement the data link layer framing methods such as character and bit stuffing.

Answer:

#include <stdio.h>
#include <string.h>

// Character Stuffing
void charStuffing(char data[]) {
    int i;
    printf("Character Stuffed Data: ");
    printf("DLE STX ");
    for(i = 0; i < strlen(data); i++) {
        if(data[i] == 'D')
            printf("DLE ");
        printf("%c", data[i]);
    }
    printf(" DLE ETX\n");
}

// Bit Stuffing
void bitStuffing(char data[]) {
    int i, count = 0;
    printf("Bit Stuffed Data: ");
    for(i = 0; i < strlen(data); i++) {
        printf("%c", data[i]);
        if(data[i] == '1') {
            count++;
            if(count == 5) {
                printf("0");
                count = 0;
            }
        } else {
            count = 0;
        }
    }
    printf("\n");
}

int main() {
    char data[50];

    printf("Enter binary data: ");
    scanf("%s", data);

    charStuffing(data);
    bitStuffing(data);

    return 0;
}


