Q2) B) Write a C program to implement framing using the Character Count Method.

Answer:

#include <stdio.h>
#include <string.h>

int main() {
    char data[100];
    int len;

    printf("Enter data: ");
    scanf("%s", data);

    len = strlen(data);

    printf("Framed Data (Character Count Method):\n");
    printf("%d %s\n", len, data);

    return 0;
}


