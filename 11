Q2) B) Write a program to version with menu-based switch configuration simulation.

Answer:

#include <stdio.h>

int main() {
    int choice;

    do {
        printf("\nSwitch Configuration Menu\n");
        printf("1. Show Running Config\n");
        printf("2. Configure VLAN\n");
        printf("3. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                printf("Displaying running configuration...\n");
                break;
            case 2:
                printf("Configuring VLAN...\n");
                break;
            case 3:
                printf("Exiting...\n");
                break;
            default:
                printf("Invalid choice\n");
        }

    } while(choice != 3);

    return 0;
}


