Q2) B) Write a program to display a Mesh Topology.

Answer:

#include <stdio.h>

int main() {
    int n, i, j;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    printf("\nMesh Topology:\n\n");

    for(i = 1; i <= n; i++) {
        for(j = 1; j <= n; j++) {
            if(i != j)
                printf("Node%d <--> Node%d\n", i, j);
        }
    }

    return 0;
}


