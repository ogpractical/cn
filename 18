Q2) B) Write a C program that simulates a NAT system.

Answer:

#include <stdio.h>

int main() {
    char privateIP[20], publicIP[20];

    printf("Enter Private IP: ");
    scanf("%s", privateIP);

    printf("Enter Public IP: ");
    scanf("%s", publicIP);

    printf("\nNAT Mapping:\n");
    printf("Private IP: %s --> Public IP: %s\n", privateIP, publicIP);

    return 0;
}


