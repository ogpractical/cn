Q2) B) Write a C program to implement CRC Code.

Answer:

#include <stdio.h>
#include <string.h>

void xorOperation(char *dividend, char *divisor, char *result) {
    int i;
    for(i = 1; i < strlen(divisor); i++) {
        result[i-1] = (dividend[i] == divisor[i]) ? '0' : '1';
    }
}

int main() {
    char data[50], divisor[20];
    char dividend[100], temp[50];
    int i;

    printf("Enter data: ");
    scanf("%s", data);

    printf("Enter divisor: ");
    scanf("%s", divisor);

    strcpy(dividend, data);

    // Append zeros
    for(i = 0; i < strlen(divisor)-1; i++) {
        strcat(dividend, "0");
    }

    strncpy(temp, dividend, strlen(divisor));

    for(i = strlen(divisor); i <= strlen(dividend); i++) {
        if(temp[0] == '1')
            xorOperation(temp, divisor, temp);
        else {
            char zeros[20];
            for(int j = 0; j < strlen(divisor); j++)
                zeros[j] = '0';
            xorOperation(temp, zeros, temp);
        }
        temp[strlen(divisor)-1] = dividend[i];
    }

    printf("CRC Remainder: %s\n", temp);
    printf("Transmitted Data: %s%s\n", data, temp);

    return 0;
}


