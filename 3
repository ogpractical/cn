Q2) B) Write a C program to display Bus Topology

Answer:

#include <stdio.h>

int main() {
    int n, i;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    printf("\nBus Topology:\n\n");

    // Print nodes
    for(i = 0; i < n; i++) {
        printf("Node%d", i+1);
        if(i != n-1)
            printf(" --- ");
    }

    printf("\n");

    return 0;
}


