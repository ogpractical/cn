Q2) B) Write a program to display Star Topology.

Answer:

#include <stdio.h>

int main() {
    int n, i;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    printf("\nStar Topology:\n\n");

    for(i = 0; i < n; i++) {
        printf("   Node%d\n", i+1);
        printf("     |\n");
    }

    printf("   [Hub/Switch]\n");

    return 0;
}


