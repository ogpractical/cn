Q2) B) Write a program to determine IP address class.

Answer:

#include <stdio.h>

int main() {
    int a, b, c, d;

    printf("Enter IP address (a.b.c.d): ");
    scanf("%d.%d.%d.%d", &a, &b, &c, &d);

    if(a >= 1 && a <= 126)
        printf("Class A\n");
    else if(a >= 128 && a <= 191)
        printf("Class B\n");
    else if(a >= 192 && a <= 223)
        printf("Class C\n");
    else if(a >= 224 && a <= 239)
        printf("Class D\n");
    else if(a >= 240 && a <= 255)
        printf("Class E\n");
    else
        printf("Invalid IP\n");

    return 0;
}


