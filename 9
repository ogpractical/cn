    struct Route r;

    strcpy(r.destination, "192.168.2.0");
    strcpy(r.gateway, "192.168.1.1");

    printf("Static Routing Table:\n");
    printf("Destination: %s\n", r.destination);
    printf("Gateway: %s\n", r.gateway);

    return 0;
}


